<h1>New Entry</h1>
<%= form_with(model: @entry) do |form| %>
<div>
    <%= form.label :name %>
    <%= form.text_field :name %>
</div>
<div>
    <%= form.label :description %>
    <%= form.text_area :description %>
</div>
<div>
    <%= form.submit %>
</div>
<% end %>

<br>

<div>
    <%= link_to "Back to home", entries_path %>
</div>