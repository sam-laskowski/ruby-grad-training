<% owner = @game_post.user_owner %>
<% pending_enrollments = (@pending_enrollments || []) %>
<% is_owner = user_signed_in? && current_user == owner %>

<div class="container py-4">
  <style>
    :root {
      --salmon: #FA8072;
      --salmon-soft: #FFE4DE;
      --salmon-ink: #3A2B2B;
      --salmon-border: rgba(250, 128, 114, 0.35);
    }

    .btn-salmon {
      background: var(--salmon);
      border-color: var(--salmon);
      color: #fff;
    }

    .btn-salmon:hover {
      background: #f56f61;
      border-color: #f56f61;
      color: #fff;
    }

    .dropin-card {
      background: #ffffff;
      border: 1px solid rgba(0, 0, 0, 0.06);
      border-radius: 1rem;
    }

    .dropin-card-soft {
      background: linear-gradient(135deg, var(--salmon-soft), #ffffff);
      border: 1px solid var(--salmon-border);
      border-radius: 1rem;
    }

    .dropin-cover {
      width: 132px;
      height: 132px;
      border-radius: 1rem;
      object-fit: cover;
      object-position: center;
      box-shadow: 0 0.25rem 0.75rem rgba(0, 0, 0, 0.08);
      border: 1px solid var(--salmon-border);
      background: #fff;
    }

    .dropin-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      overflow: hidden;
      border: 1px solid var(--salmon-border);
      background: var(--salmon-soft);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .dropin-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .dropin-attendee-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      overflow: hidden;
      border: 1px solid var(--salmon-border);
      background: var(--salmon-soft);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .dropin-attendee-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .dropin-more-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--salmon-soft);
      border: 1px solid var(--salmon-border);
      color: var(--salmon-ink);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.75rem;
    }

    .dropin-status-pill-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0.7rem;
      border-radius: 9999px;
      border: 1px solid var(--salmon-border);
      background: var(--salmon-soft);
      color: var(--salmon-ink);
      font-weight: 600;
    }

    .dropin-table th,
    .dropin-table td {
      vertical-align: middle;
      border-color: rgba(250, 128, 114, 0.18);
    }

    .game-post-owner-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      border-radius: 50%;
    }

    .game-post-attendee-avatar {
      width: 32px;
      height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--salmon-soft);
      border: 1px solid var(--salmon-border);
      margin-right: 0.25rem;
    }

    .game-post-attendee-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      border-radius: 50%;
    }

    .game-post-more-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--salmon-soft);
      border: 1px solid var(--salmon-border);
      color: var(--salmon-ink);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.75rem;
    }
  </style>

  <div class="row g-4 align-items-start">
    <div class="">
      <div class="dropin-card-soft p-3 p-md-4">
        <div class="d-flex flex-column flex-md-row gap-4 align-items-start">
          <div class="flex-shrink-0">
            <% if @game_post.cover_image.attached? %>
              <%= image_tag @game_post.cover_image.variant(:thumb), alt: "#{@game_post.name} cover", class: "dropin-cover" %>
            <% elsif @game_post.images.attached? %>
              <%= image_tag @game_post.images.first.variant(resize_to_fill: [132, 132]).processed, alt: "#{@game_post.name} cover", class: "dropin-cover" %>
            <% else %>
              <div class="dropin-cover d-flex align-items-center justify-content-center">
                <i class="bi bi-image fs-1" style="color: var(--salmon-ink); opacity: 0.65;"></i>
              </div>
            <% end %>
          </div>

          <div class="min-w-0 flex-grow-1">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
              <h1 class="h3 fw-bold mb-0" style="color: var(--salmon-ink);"><%= @game_post.name %></h1>
              <span class="dropin-status-pill-pill">
                <i class="bi bi-circle-fill" style="color: var(--salmon); font-size: 0.5rem;"></i>
                <span class="text-capitalize"><%= @game_post.status.humanize %></span>
              </span>
            </div>

            <div class="d-flex align-items-center gap-3 mb-3">
              <div class="dropin-avatar">
                <% if owner&.photo&.attached? %>
                  <%= image_tag owner.photo.variant(resize_to_fill: [44, 44]).processed, alt: "#{owner.username} profile" %>
                <% else %>
                  <i class="bi bi-person-circle text-muted fs-4"></i>
                <% end %>
              </div>
              <div class="min-w-0">
                <div class="fw-semibold text-truncate"><%= owner&.name %></div>
                <div class="text-muted small">@<%= owner&.username %></div>
              </div>
              <div class="ms-auto">
                <div class="text-muted small">
                  Attendees:
                  <span style="color: var(--salmon-ink); font-weight: 700;">
                    <%= @game_post.accepted_subscribers.count %>
                  </span>
                  / <%= @game_post.total_players %>
                </div>
              </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mb-3">
              <% if @game_post.location.present? %>
                <span class="badge" style="background: var(--salmon-soft); color: var(--salmon-ink); border: 1px solid var(--salmon-border);">
                  <i class="bi bi-geo-alt me-1"></i><%= @game_post.location %>
                </span>
              <% end %>
              <% if @game_post.time_start.present? %>
                <span class="badge text-muted border" style="border-color: var(--salmon-border) !important;">
                  <i class="bi bi-clock me-1"></i>
                  <%= @game_post.time_start.strftime("%a %H:%M") %>
                </span>
              <% end %>
            </div>

            <% if @game_post.description.present? %>
              <p class="mb-0 text-muted" style="display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;">
                <%= @game_post.description %>
              </p>
            <% end %>
          </div>
        </div>
      </div>

      <% confirmed_subscribers = @game_post.accepted_subscribers %>
      <div class="dropin-card p-3 p-md-4 my-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="min-w-0">
              <div class="small text-muted mb-1">Confirmed members</div>
              <div class="d-flex align-items-center flex-wrap">
                <% confirmed_subscribers.limit(6).each do |sub| %>
                  <% popover_content = capture do %>
                    <div class="d-flex align-items-center gap-2 mb-2">
                      <% if sub.photo&.attached? %>
                        <%= image_tag sub.photo.variant(resize_to_fill: [40, 40]).processed, alt: "#{sub.username} profile", class: "rounded-circle" %>
                      <% else %>
                        <i class="bi bi-person-circle text-muted" style="font-size: 2rem;"></i>
                      <% end %>
                      <div class="min-w-0">
                        <div class="fw-semibold text-dark text-truncate"><%= sub.name.presence || sub.username %></div>
                        <div class="text-muted small text-truncate">@<%= sub.username %></div>
                      </div>
                    </div>
                    <%= link_to "View profile", public_profile_path(sub), class: "btn btn-sm btn-salmon w-100 text-white" %>
                  <% end %>

                  <button
                    type="button"
                    class="game-post-attendee-avatar rounded-circle overflow-hidden p-0"
                    data-bs-container="body"
                    data-bs-toggle="popover"
                    data-bs-trigger="hover focus"
                    data-bs-placement="top"
                    data-bs-html="true"
                    data-bs-content="<%= popover_content.gsub("\n", "").squish %>"
                    aria-label="View <%= sub.username %> details"
                  >
                    <% if sub.photo&.attached? %>
                      <%= image_tag sub.photo.variant(resize_to_fill: [32, 32]).processed, alt: "#{sub.username} profile" %>
                    <% else %>
                      <i class="bi bi-person-circle text-muted fs-5"></i>
                    <% end %>
                  </button>
                <% end %>

                <% if confirmed_subscribers.count > 6 %>
                  <div class="game-post-more-avatar">+<%= confirmed_count - 6 %></div>
                <% end %>
              </div>
            </div>
        </div>
    </div>

    <div class="d-flex">
      <div class="dropin-card p-3 p-md-4 col-lg-4">
        <% if is_owner %>
          <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
              <div class="small text-muted mb-1">Owner options</div>
              <div class="fw-bold" style="color: var(--salmon-ink);">Manage this post</div>
            </div>
            <i class="bi bi-shield-check" style="color: var(--salmon); font-size: 1.2rem;"></i>
          </div>

          <% if @game_post.open? || @game_post.full? %>
            <div class="d-grid gap-2">
              <%= button_to "Delete", @game_post, method: :delete, class: "btn btn-outline-secondary" %>
              <%= button_to "Confirm Event", confirm_game_post_path(@game_post), method: :patch, class: "btn btn-salmon" %>
            </div>
          <% else %>
            <div class="text-muted small">
              This post cannot be confirmed right now.
            </div>
          <% end %>
        <% else %>
          <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
              <div class="small text-muted mb-1">Join this dropin</div>
              <div class="fw-bold" style="color: var(--salmon-ink);">Your action</div>
            </div>
            <i class="bi bi-people" style="color: var(--salmon); font-size: 1.2rem;"></i>
          </div>

          <% if user_signed_in? %>
            <% my_enrollment = current_user.enrollments.find_by(game_post: @game_post) %>
            <% my_state = my_enrollment&.status %>

            <% has_owned_post = current_user.owned_games.exists? %>
            <% has_active_other_enrollment = current_user.enrollments.where(status: [:pending, :accepted]).where.not(game_post_id: @game_post.id).exists? %>
            <% can_request = !has_owned_post && !has_active_other_enrollment %>

            <% if my_state == "pending" %>
              <span class="badge" style="background: var(--salmon-soft); color: var(--salmon-ink); border: 1px solid var(--salmon-border);">
                Request pending
              </span>
              <div class="mt-3">
                <%= button_to "Unrequest", game_post_enrollment_path(@game_post, my_enrollment), method: :delete, class: "btn btn-outline-secondary w-100" %>
              </div>
            <% elsif my_state == "accepted" %>
              <% if @game_post.confirmed? %>
                <span class="badge text-bg-success">Confirmed</span>
              <% else %>
                <span class="badge" style="background: var(--salmon-soft); color: var(--salmon-ink); border: 1px solid var(--salmon-border);">
                  Accepted (awaiting confirmation)
                </span>
              <% end %>
            <% elsif my_state == "rejected" %>
              <span class="badge text-bg-secondary">Request rejected</span>
            <% else %>
              <% if can_request %>
                <%= button_to "Request to join", game_post_enrollments_path(@game_post), method: :post, class: "btn btn-salmon w-100" %>
              <% else %>
                <%= button_to "Request to join", game_post_enrollments_path(@game_post), method: :post, disabled: true, class: "btn btn-salmon w-100" %>
              <% end %>
            <% end %>
          <% else %>
            <%= button_to "Log in to request", login_path, method: :get, class: "btn btn-salmon w-100" %>
          <% end %>
        <% end %>
      </div>

      <% if is_owner %>
        <div class="dropin-card p-3 p-md-4 col-lg-4 mx-4">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <h2 class="h6 mb-0">Pending requests</h2>
            <span class="badge" style="background: var(--salmon-soft); color: var(--salmon-ink); border: 1px solid var(--salmon-border);">
              <%= pending_enrollments.size %>
            </span>
          </div>

          <% if pending_enrollments.any? %>
            <div class="table-responsive">
              <table class="table dropin-table align-middle mb-0">
                <thead>
                  <tr>
                    <th>User</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% pending_enrollments.each do |enrollment| %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center gap-2">
                          <div class="dropin-avatar" style="width: 36px; height: 36px;">
                            <% if enrollment.user&.photo&.attached? %>
                              <%= image_tag enrollment.user.photo.variant(resize_to_fill: [36, 36]).processed, alt: "#{enrollment.user.username} profile" %>
                            <% else %>
                              <i class="bi bi-person-circle text-muted fs-4"></i>
                            <% end %>
                          </div>
                          <div class="min-w-0 d-flex flex-column">
                            <%= link_to "#{enrollment.user&.name}", public_profile_path(owner), class: "text-truncate fw-semibold text-black text-decoration-none" %>
                            <%= link_to "@#{enrollment.user&.username}", public_profile_path(owner), class: "text-muted small text-decoration-none" %>
                          </div>
                        </div>
                      </td>
                      <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                          <%= button_to "Accept", game_post_enrollment_path(@game_post, enrollment, status: "accepted"), method: :patch, class: "btn btn-sm btn-salmon" %>
                          <%= button_to "Decline", game_post_enrollment_path(@game_post, enrollment, status: "rejected"), method: :patch, class: "btn btn-sm btn-outline-secondary" %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted mb-0">No pending requests at the moment.</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>