<% has_owned_post = current_user.owned_games.exists? %>
<% has_active_request = current_user.enrollments.where(status: [:pending, :accepted]).exists? %>

<%# Local styling for this page only (keeps the look consistent with show/navbar) %>
<style>
  :root {
    --salmon-ink: #3A2B2B;
    --salmon-soft: #FFE4DE;
    --salmon-border: rgba(250, 128, 114, 0.35);
    --secondary-salmon: #FFB070; /* requested accent color */
    --secondary-salmon-ink: #4A2C12;
  }

  .dropin-form-card-soft {
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 1rem;
  }

  .btn-secondary-salmon {
    background: var(--secondary-salmon);
    border-color: var(--secondary-salmon);
    color: var(--secondary-salmon-ink);
    font-weight: 700;
  }

  .btn-secondary-salmon:hover {
    background: #f59d5d;
    border-color: #f59d5d;
    color: var(--secondary-salmon-ink);
  }

  .dropin-accent-icon {
    color: var(--secondary-salmon);
  }

  .dropin-input-icon {
    background: rgba(255, 176, 112, 0.18);
    border-color: rgba(255, 176, 112, 0.35);
    color: var(--secondary-salmon-ink);
  }

  .dropin-file-hint {
    color: var(--salmon-ink);
    opacity: 0.75;
  }
</style>

<div class="container py-4">
  <% if !has_owned_post && !has_active_request %>
    <div class="row g-4 align-items-start">
      <div class="col-lg-8">
        <div class="dropin-form-card-soft p-3 p-md-4">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
            <div>
              <h1 class="h3 fw-bold mb-1" style="color: var(--salmon-ink);">
                <i class="bi bi-plus-circle dropin-accent-icon me-2" aria-hidden="true"></i>
                Create a new dropin
              </h1>
            </div>
          </div>

          <%= form_with model: @game_post do |form| %>
            <div class="row g-3">
              <div class="col-12 col-md-6">
                <%= form.label :name, class: "form-label" do %>
                  <i class="bi bi-bullseye dropin-accent-icon me-2" aria-hidden="true"></i>
                  Activity
                <% end %>
                <%= form.text_field :name, required: true, class: "form-control", placeholder: "e.g., Codenames" %>
              </div>

              <div class="col-12 col-md-6">
                <%= form.label :location, class: "form-label" do %>
                  <i class="bi bi-geo-alt dropin-accent-icon me-2" aria-hidden="true"></i>
                  Location
                <% end %>
                <%= form.text_field :location, required: true, class: "form-control", placeholder: "e.g., Victoria" %>
              </div>

              <%# Start time + duration on the same line (md+) %>
              <div class="col-12 col-md-6">
                <%= form.label :time_start, class: "form-label" do %>
                  <i class="bi bi-clock dropin-accent-icon me-2" aria-hidden="true"></i>
                  Start time
                <% end %>
                <div class="input-group">
                  <span class="input-group-text dropin-input-icon" aria-hidden="true">
                    <i class="bi bi-clock"></i>
                  </span>
                  <%= form.time_field :time_start, required: true, class: "form-control" %>
                </div>
              </div>

              <div class="col-12 col-md-6">
                <%= form.label :duration, class: "form-label" do %>
                  <i class="bi bi-hourglass-split dropin-accent-icon me-2" aria-hidden="true"></i>
                  Duration (hours)
                <% end %>
                <div class="input-group">
                  <span class="input-group-text dropin-input-icon" aria-hidden="true">
                    <i class="bi bi-hourglass-split"></i>
                  </span>
                  <%= form.number_field :duration,
                    in: 1..23,
                    step: 1,
                    required: false,
                    class: "form-control",
                    placeholder: "e.g., 2" %>
                </div>
                <div class="form-text dropin-file-hint">Optional</div>
              </div>

              <div class="col-12 col-md-6">
                <%= form.label :total_players, class: "form-label" do %>
                  <i class="bi bi-people dropin-accent-icon me-2" aria-hidden="true"></i>
                  Spaces
                <% end %>
                <%= form.number_field :total_players,
                  in: 1..10,
                  step: 1,
                  required: true,
                  class: "form-control",
                  placeholder: "e.g., 4" %>
                <div class="form-text dropin-file-hint">Including yourself.</div>
              </div>

              <div class="col-12 col-md-6">
                <%= form.label :images, class: "form-label" do %>
                  <i class="bi bi-images dropin-accent-icon me-2" aria-hidden="true"></i>
                  Photos (optional)
                <% end %>
                <%= form.file_field :images, multiple: true, class: "form-control" %>
                <div class="form-text dropin-file-hint">Add up to a few images to set the vibe.</div>
              </div>

              <div class="col-12">
                <%= form.label :description, class: "form-label" do %>
                  <i class="bi bi-chat-left-text dropin-accent-icon me-2" aria-hidden="true"></i>
                  Description
                <% end %>
                <%= form.text_area :description, required: false, class: "form-control", rows: 4, placeholder: "Any extra information" %>
              </div>

              <div class="col-12 d-flex flex-column flex-md-row gap-2 align-items-md-center">
                <%= form.submit "Create",
                  class: "btn btn-secondary-salmon w-100 w-md-auto px-4" %>
                <span class="text-muted small text-center text-md-start">
                  You can only have one active post or request at a time.
                </span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="dropin-form-card-soft p-3 p-md-4">
      <div class="d-flex align-items-start justify-content-between gap-3">
        <div>
          <h2 class="h5 fw-bold mb-1" style="color: var(--salmon-ink);">
            <i class="bi bi-lock-fill dropin-accent-icon me-2" aria-hidden="true"></i>
            Action limited
          </h2>
          <p class="text-muted mb-0">You can only have one active post or request at a time.</p>
        </div>
        <span class="badge" style="background: rgba(255, 176, 112, 0.22); color: var(--secondary-salmon-ink); border: 1px solid rgba(255, 176, 112, 0.45);">
          <i class="bi bi-hourglass-split me-1" aria-hidden="true"></i>
          Pending
        </span>
      </div>
    </div>
  <% end %>
</div>