<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">
      <div class="public-profile-card">
        <div class="p-4 p-md-5">
          <div class="text-center mb-4">
            <div class="public-profile-avatar mb-3">
              <% if @user.photo.attached? %>
                <%= image_tag @user.photo_as_thumbnail, alt: "#{@user.username} profile photo" %>
              <% else %>
                <i class="bi bi-person-circle" style="font-size: 3rem;"></i>
              <% end %>
            </div>
            <h2 class="h4 mb-1" style="color: #4d2d28;"><%= @user.name.presence || @user.username %></h2>
            <p class="mb-0 text-muted">@<%= @user.username %></p>
          </div>

          <div class="row g-3">
            <div class="col-12">
              <div class="p-3" style="border: 1px solid;">
                <div class="public-profile-label">Bio</div>
                <div class="public-profile-value">
                  <%= @user.bio.presence || "This user has not added a bio yet." %>
                </div>
              </div>
            </div>

            <div class="col-12 col-sm-6">
              <div class="p-3 h-100" style="background: #ffffff; border: 1px solid;">
                <div class="public-profile-label">Posts Created</div>
                <div class="public-profile-value"><%= @user.owned_games.count %></div>
              </div>
            </div>

            <div class="col-12 col-sm-6">
              <div class="p-3 h-100" style="background: #ffffff; border: 1px solid;">
                <div class="public-profile-label">Joined</div>
                <div class="public-profile-value"><%= @user.created_at.strftime("%b %Y") %></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>