<h1 class="mb-4">All Entries</h1>
<div class="list-group">
  <% @entries.each do |entry| %>
    <div class="list-group-item d-flex justify-content-between align-items-start mb-3 rounded shadow-sm">
      <div class="me-3">
        <h2 class="h5 mb-1"><%= entry.name %></h2>
        <p class="mb-0 text-muted"><%= entry.description %></p>
      </div>

      <%= button_to "Delete", entry, method: :delete, data: { confirm: "Are you sure you want to delete this Project" }, class: "btn btn-danger btn-sm rounded" %>
    </div>
  <% end %>
</div>

<div class="mt-4 text-center">
  <%= link_to "Create Entry", new_entry_path, class: "btn btn-primary btn-lg rounded px-4" %>
</div>
