<div>Onboarding for <%= @user.username %></div>
<h1>Complete Your Profile</h1>
<p>Tell us a bit more about yourself (optional).</p>

<%= form_with model: @user, url: onboarding_path(@user), method: :patch, local: true do |f| %>

  <% if @user.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@user.errors.count, "error") %> prohibited this profile from being saved:</h2>
      <ul>
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label "Full name" %>
    <%= f.text_field :name, placeholder: "Sam" %>
  </div>

  <div class="field">
    <%= f.label :bio %>
    <%= f.text_area :bio, placeholder: "Share a little about yourself..." %>
  </div>

  <div class="field">
    <%= f.label :photo %>
    <%= f.file_field :photo %>
  </div>

  <div class="actions">
    <%= f.submit "Save and Continue", class: "button-primary" %>
    <%= link_to "Skip for now", game_posts_path, class: "button-secondary" %>
  </div>

<% end %>