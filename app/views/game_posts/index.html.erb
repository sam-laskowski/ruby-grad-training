<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="h5 mb-0 text-muted">All live listings</h2>
    <span class="badge" style="background: var(--salmon-soft); color: var(--salmon-ink); border: 1px solid var(--salmon-border);">
      <%= @game_posts.size %> posts
    </span>
  </div>

  <% if user_signed_in? %>
    <% has_active_request = current_user.enrollments.where(status: [:pending, :accepted]).exists? %>
    <% has_owned_post = current_user.owned_games.exists? %>
  <% end %>

  <div class="row row-cols-1 row-cols-md-2 g-4">
    <% @game_posts.each do |game_post| %>
      <% owner = game_post.user_owner %>
      <% confirmed_subscribers = game_post.accepted_subscribers %>
      <% confirmed_count = confirmed_subscribers.count %>
      <% total_players = game_post.total_players.to_i %>
      <% time_start = game_post.time_start %>

      <div class="col">
        <div class="game-post-card h-100 shadow-sm">
          <div class="position-relative game-post-card-body p-3">
            <div class="position-absolute top-0 end-0 p-3">
              <% if game_post.cover_image.attached? %>
                <%= image_tag game_post.cover_image.variant(:thumb), alt: "#{game_post.name} cover", class: "game-post-cover" %>
              <% elsif game_post.images.attached? %>
                <%= image_tag game_post.images.first.variant(resize_to_fill: [96, 96]).processed, alt: "#{game_post.name} cover", class: "game-post-cover" %>
              <% else %>
                <div class="game-post-cover-placeholder d-flex align-items-center justify-content-center">
                  <i class="bi bi-image fs-4"></i>
                </div>
              <% end %>
            </div>

            <div class="d-flex align-items-start justify-content-between gap-3">
              <div class="min-w-0">
                <h3 class="h5 fw-bold mb-1 game-post-title">
                  <%= link_to game_post.name, game_post_path(game_post), class: "text-decoration-none game-post-title" %>
                </h3>

                <div class="d-flex align-items-center gap-2 mb-2">
                  <div class="game-post-owner-avatar rounded-circle overflow-hidden">
                    <% if owner&.photo&.attached? %>
                      <%= image_tag owner.photo.variant(resize_to_fill: [44, 44]).processed, alt: "#{owner.username} profile" %>
                    <% else %>
                      <i class="bi bi-person-circle text-muted fs-4"></i>
                    <% end %>
                  </div>

                  <div class="min-w-0 d-flex flex-column">
                    <%= link_to "#{owner&.name}", public_profile_path(owner), class: "text-truncate fw-semibold text-black text-decoration-none" %>
                    <%= link_to "@#{owner&.username}", public_profile_path(owner), class: "text-muted small text-decoration-none" %>
                  </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mb-2">
                  <% if game_post.location.present? %>
                    <span class="badge" style="background: var(--salmon-soft); color: var(--salmon-ink); border: 1px solid var(--salmon-border);">
                      <i class="bi bi-geo-alt me-1"></i><%= game_post.location %>
                    </span>
                  <% end %>

                  <% if time_start.present? %>
                    <span class="badge text-muted border" style="border-color: var(--salmon-border) !important;">
                      <i class="bi bi-clock me-1"></i>
                        <%= time_start.strftime("%a %H:%M") %>
                    </span>
                  <% end %>
                </div>

                <div class="text-muted small mb-3">
                  Attendees: <span class="fw-semibold" style="color: var(--salmon-ink);"><%= confirmed_count %></span>/<%= total_players %>
                  <% if time_start.present? %>
                    <span class="ms-2">in <%= time_ago_in_words(time_start) %></span>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
              <div class="min-w-0">
                <div class="small text-muted mb-1">Confirmed members</div>
                <div class="d-flex align-items-center flex-wrap">
                  <% confirmed_subscribers.limit(6).each do |sub| %>
                    <% popover_content = capture do %>
                      <div class="d-flex align-items-center gap-2 mb-2">
                        <% if sub.photo&.attached? %>
                          <%= image_tag sub.photo.variant(resize_to_fill: [40, 40]).processed, alt: "#{sub.username} profile", class: "rounded-circle" %>
                        <% else %>
                          <i class="bi bi-person-circle text-muted" style="font-size: 2rem;"></i>
                        <% end %>
                        <div class="min-w-0">
                          <div class="fw-semibold text-dark text-truncate"><%= sub.name.presence || sub.username %></div>
                          <div class="text-muted small text-truncate">@<%= sub.username %></div>
                        </div>
                      </div>
                      <%= link_to "View profile", public_profile_path(sub), class: "btn-salmon" %>
                    <% end %>

                    <button
                      type="button"
                      class="game-post-attendee-avatar rounded-circle overflow-hidden p-0"
                      data-bs-container="body"
                      data-bs-toggle="popover"
                      data-bs-trigger="hover focus"
                      data-bs-placement="top"
                      data-bs-html="true"
                      data-bs-content="<%= popover_content.gsub("\n", "").squish %>"
                      aria-label="View <%= sub.username %> details"
                    >
                      <% if sub.photo&.attached? %>
                        <%= image_tag sub.photo.variant(resize_to_fill: [32, 32]).processed, alt: "#{sub.username} profile" %>
                      <% else %>
                        <i class="bi bi-person-circle text-muted fs-5"></i>
                      <% end %>
                    </button>
                  <% end %>

                  <% if confirmed_count > 6 %>
                    <div class="game-post-more-avatar">+<%= confirmed_count - 6 %></div>
                  <% end %>
                </div>
              </div>

              <div class="ms-auto">
                <% if user_signed_in? %>
                  <% if game_post.enrollments.exists?(user_id: current_user.id, status: 'accepted') %>
                    <span class="badge text-bg-success">Confirmed</span>
                  <% else %>
                    <% if !has_owned_post && !has_active_request %>
                      <%= subscription_button_for(game_post, class: "btn-salmon") %>
                    <% else %>
                      <%= subscription_button_for(game_post, hidden: true, class: "btn-salmon") %>
                    <% end %>
                  <% end %>
                <% end %>
              </div>
            </div>

            <% if game_post.description.present? %>
              <p class="mt-3 mb-0 small text-muted" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                <%= game_post.description %>
              </p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>