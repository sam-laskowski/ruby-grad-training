<h1><%= @game_post.name %></h1>
<% if @game_post.images.attached? %>
  <% @game_post.images.each do |image| %>
      <%= image_tag(image) %>
  <% end %>
    <% image_tag @game_post.images.first %>
<% end %>
<h3>Attendees: <%= @game_post.accepted_subscribers.count %>/<%= @game_post.total_players %></h3>

<% if current_user == @game_post.user_owner %>
  <% if @game_post.open? || @game_post.full? %>
    <%= button_to "Delete", @game_post, method: :delete %>
    <%= button_to "Confirm Event", confirm_game_post_path(@game_post), method: :patch  %>
  <% end %>
  <section class="owner-controls">
    <h2>Pending Requests</h2>
    <% if @pending_enrollments.any? %>
      <table>
        <thead>
          <tr>
            <th>User</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @pending_enrollments.each do |enrollment| %>
            <tr>
              <td><%= enrollment.user.username %></td>
              <td>
                <%= button_to "Accept", game_post_enrollment_path(@game_post, enrollment, status: 'accepted'), method: :patch %>
                <%= button_to "Decline", game_post_enrollment_path(@game_post, enrollment, status: 'rejected'), method: :patch %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No pending requests at the moment.</p>
    <% end %>
  </section>
<% end %>